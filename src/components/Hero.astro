---
// Hero section component
---

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <span class="badge badge-mint">AI-Powered Email Marketing</span>
      <h1>Email Flows That Match Your Brand Voice</h1>
      <p class="hero-subtitle">
        FlowMint analyzes your Shopify store and generates personalized email campaigns in minutes, not hours. Push them directly to Klaviyo, Mailchimp, or your ESP of choice.
      </p>
      <div class="hero-cta">
        <a href="#" class="btn btn-primary btn-lg">
          Install Free on Shopify
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
        <a href="#how-it-works" class="btn btn-secondary btn-lg">
          See How It Works
        </a>
      </div>
      <p class="hero-note">Free tier available. No credit card required.</p>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-20) 0 var(--space-24);
    background: linear-gradient(180deg, var(--mint-bg) 0%, var(--bg-white) 100%);
    text-align: center;
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero .badge {
    margin-bottom: var(--space-6);
  }

  .hero h1 {
    font-size: var(--text-4xl);
    line-height: 1.1;
    margin-bottom: var(--space-6);
    color: var(--slate-900);
  }

  @media (min-width: 768px) {
    .hero h1 {
      font-size: var(--text-5xl);
    }
  }

  .hero-subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    margin-bottom: var(--space-8);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 768px) {
    .hero-subtitle {
      font-size: var(--text-xl);
    }
  }

  .hero-cta {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    justify-content: center;
    align-items: center;
    margin-bottom: var(--space-6);
  }

  @media (min-width: 640px) {
    .hero-cta {
      flex-direction: row;
    }
  }

  .hero-note {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
</style>
