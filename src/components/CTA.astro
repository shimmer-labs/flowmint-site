---
// Call-to-action banner section
---

<section class="cta-section">
  <div class="container">
    <div class="cta-content">
      <h2>Ready to Transform Your Email Marketing?</h2>
      <p>Join Shopify merchants who are saving hours on email campaigns with AI-powered flows that actually convert.</p>
      <div class="cta-buttons">
        <a href="#" class="btn btn-primary btn-lg">
          Install Free on Shopify
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>
      <p class="cta-note">Free tier available. No credit card required.</p>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: linear-gradient(135deg, var(--slate-900) 0%, var(--slate-800) 100%);
    padding: var(--space-20) 0;
    text-align: center;
  }

  .cta-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-content h2 {
    color: white;
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }

  @media (min-width: 768px) {
    .cta-content h2 {
      font-size: var(--text-4xl);
    }
  }

  .cta-content > p {
    color: var(--slate-300);
    font-size: var(--text-lg);
    margin-bottom: var(--space-8);
  }

  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .cta-note {
    font-size: var(--text-sm);
    color: var(--slate-400);
  }
</style>
