---
// Pricing section
const plans = [
  {
    name: "Free",
    price: "$0",
    period: "forever",
    description: "Perfect for trying out FlowMint",
    features: [
      "Unlimited brand analysis",
      "Generate 1 flow for preview",
      "View all flow recommendations",
      "Copy/paste export"
    ],
    cta: "Get Started Free",
    ctaLink: "#",
    highlighted: false
  },
  {
    name: "Starter",
    price: "$49",
    period: "/month",
    description: "Everything you need to launch email marketing",
    features: [
      "Unlimited flow generation",
      "Push to Klaviyo, Mailchimp & more",
      "All 18+ flow types",
      "Email support",
      "Regenerate templates anytime"
    ],
    cta: "Start 7-Day Trial",
    ctaLink: "#",
    highlighted: true
  },
  {
    name: "Pro",
    price: "$149",
    period: "/month",
    description: "Advanced features for growing brands",
    features: [
      "Everything in Starter",
      "Automated flow creation",
      "Campaign calendar",
      "Analytics & ROI tracking",
      "Priority support"
    ],
    cta: "Coming Soon",
    ctaLink: "#",
    highlighted: false,
    comingSoon: true
  }
];
---

<section class="pricing section" id="pricing">
  <div class="container">
    <div class="section-header text-center">
      <h2>Simple, Transparent Pricing</h2>
      <p class="section-subtitle">Start free, upgrade when you're ready</p>
    </div>

    <div class="pricing-grid">
      {plans.map((plan) => (
        <div class={`pricing-card ${plan.highlighted ? 'highlighted' : ''} ${plan.comingSoon ? 'coming-soon' : ''}`}>
          {plan.highlighted && <span class="popular-badge">Most Popular</span>}
          {plan.comingSoon && <span class="coming-soon-badge">Coming Soon</span>}

          <h3>{plan.name}</h3>
          <div class="price">
            <span class="price-amount">{plan.price}</span>
            <span class="price-period">{plan.period}</span>
          </div>
          <p class="plan-description">{plan.description}</p>

          <ul class="plan-features">
            {plan.features.map((feature) => (
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          <a
            href={plan.ctaLink}
            class={`btn ${plan.highlighted ? 'btn-primary' : 'btn-secondary'} ${plan.comingSoon ? 'disabled' : ''}`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <p class="pricing-note text-center">
      All plans billed through Shopify. Cancel anytime.
    </p>
  </div>
</section>

<style>
  .section-header {
    margin-bottom: var(--space-12);
  }

  .section-header h2 {
    margin-bottom: var(--space-4);
  }

  .section-subtitle {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    max-width: 500px;
    margin: 0 auto;
  }

  .pricing-grid {
    display: grid;
    gap: var(--space-6);
    max-width: 1000px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .pricing-grid {
      grid-template-columns: repeat(3, 1fr);
      align-items: start;
    }
  }

  .pricing-card {
    position: relative;
    background: var(--bg-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    text-align: center;
  }

  .pricing-card.highlighted {
    border-color: var(--mint-fresh);
    box-shadow: 0 0 0 1px var(--mint-fresh), var(--shadow-lg);
    transform: scale(1.02);
  }

  .pricing-card.coming-soon {
    opacity: 0.75;
  }

  .popular-badge {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--mint-fresh);
    color: white;
    font-size: var(--text-xs);
    font-weight: 600;
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .coming-soon-badge {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--slate-600);
    color: white;
    font-size: var(--text-xs);
    font-weight: 600;
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pricing-card h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }

  .price {
    margin-bottom: var(--space-4);
  }

  .price-amount {
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--slate-900);
  }

  .price-period {
    font-size: var(--text-base);
    color: var(--text-muted);
  }

  .plan-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
  }

  .plan-features {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-8);
    text-align: left;
  }

  .plan-features li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-3);
  }

  .plan-features svg {
    flex-shrink: 0;
    color: var(--mint-fresh);
    margin-top: 2px;
  }

  .pricing-card .btn {
    width: 100%;
  }

  .pricing-card .btn.disabled {
    pointer-events: none;
    opacity: 0.6;
  }

  .pricing-note {
    margin-top: var(--space-8);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
</style>
