---
// FAQ section with accordion
const faqs = [
  {
    question: "Will the AI-generated emails actually sound like my brand?",
    answer: "Yes! FlowMint analyzes your products, blog posts, and store content to learn your unique voice. Most merchants say the first draft is 80-90% ready to use as-is. You can always edit the templates to fine-tune them."
  },
  {
    question: "What email platforms are supported?",
    answer: "We currently support one-click push to Klaviyo and Shopify Email. Template export (copy/paste) works with ANY email platform including Mailchimp, ActiveCampaign, GetResponse, Customer.io, OmniSend, and more. Direct integrations for additional platforms are coming soon."
  },
  {
    question: "How long does it take to generate email campaigns?",
    answer: "Brand analysis takes about 30-60 seconds. Email generation takes 45-60 seconds per flow (each flow contains 3 emails). You can have professional email campaigns ready in under 5 minutes."
  },
  {
    question: "Can I edit the generated templates?",
    answer: "Absolutely! All templates are fully editable. Use them as-is, or customize the copy, subject lines, and calls-to-action to your exact needs. When you push to Klaviyo, templates appear as drafts that you can edit before activating."
  },
  {
    question: "Is my data secure?",
    answer: "Yes. Your email platform API keys are encrypted with AES-256-GCM (bank-level security). We're GDPR compliant, and all your data is permanently deleted within 48 hours of uninstalling the app. We never sell or share your data."
  },
  {
    question: "What's the difference between Free and Paid plans?",
    answer: "The Free plan lets you run unlimited brand analysis and generate 1 flow for preview. Paid plans unlock unlimited flow generation, direct push to email platforms, template regeneration, and email support. See pricing above for full details."
  },
  {
    question: "Can I cancel anytime?",
    answer: "Yes! All subscriptions are billed through Shopify and you can cancel anytime. Cancellation takes effect at the end of your billing cycle, and you'll retain access until then. No hidden fees or cancellation penalties."
  },
  {
    question: "Do you offer refunds?",
    answer: "We don't offer refunds for partial months, but you retain access until your billing period ends. If the app is unusable for 7+ consecutive days due to a technical issue on our end, you may be eligible for a prorated refund."
  }
];
---

<section class="faq section" id="faq">
  <div class="container">
    <div class="section-header text-center">
      <h2>Frequently Asked Questions</h2>
      <p class="section-subtitle">Got questions? We've got answers.</p>
    </div>

    <div class="faq-list">
      {faqs.map((faq, index) => (
        <details class="faq-item">
          <summary>
            <span>{faq.question}</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </summary>
          <div class="faq-answer">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>

    <div class="faq-footer text-center">
      <p>Still have questions? <a href="mailto:logan@shimmerlabs.co">Contact us</a></p>
    </div>
  </div>
</section>

<style>
  .section-header {
    margin-bottom: var(--space-12);
  }

  .section-header h2 {
    margin-bottom: var(--space-4);
  }

  .section-subtitle {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    max-width: 500px;
    margin: 0 auto;
  }

  .faq-list {
    max-width: 800px;
    margin: 0 auto;
  }

  .faq-item {
    background: var(--bg-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-4);
    overflow: hidden;
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    cursor: pointer;
    font-weight: 600;
    color: var(--text-primary);
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary:hover {
    background: var(--slate-50);
  }

  .faq-icon {
    flex-shrink: 0;
    color: var(--text-muted);
    transition: transform var(--transition-base);
  }

  .faq-item[open] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 var(--space-6) var(--space-6);
  }

  .faq-answer p {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .faq-footer {
    margin-top: var(--space-10);
  }

  .faq-footer p {
    color: var(--text-muted);
  }

  .faq-footer a {
    color: var(--mint-dark);
    font-weight: 600;
  }

  .faq-footer a:hover {
    color: var(--mint-fresh);
  }
</style>
