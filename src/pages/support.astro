---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
  {
    question: "How do I get started with FlowMint?",
    answer: "Install FlowMint from the Shopify App Store, run brand analysis (takes ~30 seconds), review your recommended flows, and generate your first email templates. The whole process takes about 5 minutes."
  },
  {
    question: "What email platforms are supported?",
    answer: "We currently support one-click push to Klaviyo and Shopify Email. Template export (copy/paste) works with ANY email platform including Mailchimp, ActiveCampaign, GetResponse, Customer.io, OmniSend, and more."
  },
  {
    question: "Why aren't my templates matching my brand voice?",
    answer: "The AI learns from your store content. For best results, ensure you have 3-5 blog posts with your authentic voice, unique product descriptions (not generic or AI-generated), and the correct business model selected in the app."
  },
  {
    question: "I can't push templates to my email platform",
    answer: "First, verify your API key is correct and has both Read and Write permissions for Templates. For Klaviyo, ensure your key starts with 'pk_' (private key). Make sure you're on a paid plan—Free tier cannot push to platforms."
  },
  {
    question: "What happens to my data if I uninstall?",
    answer: "All your data is permanently deleted within 48 hours of uninstalling, including brand analysis, templates, and settings. This deletion is irreversible—if you reinstall later, you'll start fresh."
  },
  {
    question: "Is my API key secure?",
    answer: "Yes! All API keys are encrypted at rest using AES-256-GCM authenticated encryption (bank-level security). Keys are never logged in plain text and transmitted only over HTTPS."
  }
];
---

<BaseLayout title="Support - FlowMint" description="Get help with FlowMint. Find answers to common questions or contact our support team.">
  <section class="support-hero">
    <div class="container">
      <h1>Need Help?</h1>
      <p class="subtitle">We're here to help you get the most out of FlowMint.</p>
    </div>
  </section>

  <section class="support-content section">
    <div class="container">
      <div class="support-grid">
        <!-- Contact Card -->
        <div class="contact-card">
          <div class="contact-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          </div>
          <h2>Contact Support</h2>
          <p>For billing questions, technical issues, or GDPR data requests, reach out to our team.</p>
          <a href="mailto:logan@shimmerlabs.co" class="btn btn-primary">
            Email Us
          </a>
          <p class="contact-note">
            <strong>Email:</strong> logan@shimmerlabs.co<br>
            <strong>Response Time:</strong> Within 24-48 hours
          </p>
        </div>

        <!-- FAQ Section -->
        <div class="faq-section">
          <h2>Frequently Asked Questions</h2>
          <div class="faq-list">
            {faqs.map((faq) => (
              <details class="faq-item">
                <summary>
                  <span>{faq.question}</span>
                  <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m6 9 6 6 6-6"/>
                  </svg>
                </summary>
                <div class="faq-answer">
                  <p>{faq.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>

      <!-- Additional Resources -->
      <div class="resources-section">
        <h2>Legal & Policies</h2>
        <div class="resources-grid">
          <a href="/privacy" class="resource-card">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>
            </svg>
            <span>Privacy Policy</span>
          </a>
          <a href="/terms" class="resource-card">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
            <span>Terms of Service</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .support-hero {
    background: linear-gradient(135deg, var(--slate-900) 0%, var(--slate-800) 100%);
    padding: var(--space-16) 0;
    text-align: center;
  }

  .support-hero h1 {
    color: white;
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .support-hero .subtitle {
    color: var(--slate-300);
    font-size: var(--text-xl);
  }

  .support-grid {
    display: grid;
    gap: var(--space-10);
    margin-bottom: var(--space-16);
  }

  @media (min-width: 768px) {
    .support-grid {
      grid-template-columns: 1fr 2fr;
      gap: var(--space-12);
    }
  }

  /* Contact Card */
  .contact-card {
    background: var(--mint-bg);
    border: 1px solid var(--mint-light);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    text-align: center;
    height: fit-content;
  }

  .contact-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: var(--mint-fresh);
    color: white;
    border-radius: var(--radius-full);
    margin-bottom: var(--space-4);
  }

  .contact-card h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .contact-card > p {
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
  }

  .contact-card .btn {
    margin-bottom: var(--space-4);
  }

  .contact-note {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.8;
  }

  /* FAQ Section */
  .faq-section h2 {
    margin-bottom: var(--space-6);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .faq-item {
    background: var(--bg-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    cursor: pointer;
    font-weight: 600;
    color: var(--text-primary);
    list-style: none;
    font-size: var(--text-sm);
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary:hover {
    background: var(--slate-50);
  }

  .faq-icon {
    flex-shrink: 0;
    color: var(--text-muted);
    transition: transform var(--transition-base);
  }

  .faq-item[open] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 var(--space-5) var(--space-5);
  }

  .faq-answer p {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: 1.7;
  }

  /* Resources Section */
  .resources-section {
    border-top: 1px solid var(--border);
    padding-top: var(--space-10);
  }

  .resources-section h2 {
    text-align: center;
    margin-bottom: var(--space-6);
  }

  .resources-grid {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .resource-card {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-6);
    background: var(--bg-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    color: var(--text-primary);
    font-weight: 500;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .resource-card:hover {
    border-color: var(--mint-fresh);
    color: var(--mint-dark);
  }

  .resource-card svg {
    color: var(--mint-fresh);
  }
</style>
