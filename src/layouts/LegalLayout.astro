---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  lastUpdated?: string;
}

const { title, description, lastUpdated } = Astro.props;

const siteUrl = "https://flowmint.me";
const fullTitle = `${title} | FlowMint`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    {description && <meta name="description" content={description} />}

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={fullTitle} />

    <!-- No index for legal pages (optional) -->
    <meta name="robots" content="noindex, follow" />

    <meta name="generator" content={Astro.generator} />

    <style>
      .legal-page {
        padding: var(--space-12) 0 var(--space-24);
        min-height: 80vh;
      }

      .legal-header {
        margin-bottom: var(--space-8);
        padding-bottom: var(--space-6);
        border-bottom: 1px solid var(--border);
      }

      .legal-header h1 {
        margin-bottom: var(--space-2);
      }

      .legal-meta {
        color: var(--text-muted);
        font-size: var(--text-sm);
      }

      .legal-content {
        max-width: var(--max-width-prose);
      }

      .legal-content :global(h2) {
        margin-top: var(--space-10);
        margin-bottom: var(--space-4);
        font-size: var(--text-2xl);
      }

      .legal-content :global(h3) {
        margin-top: var(--space-8);
        margin-bottom: var(--space-3);
        font-size: var(--text-xl);
      }

      .legal-content :global(p) {
        margin-bottom: var(--space-4);
        color: var(--text-secondary);
      }

      .legal-content :global(ul),
      .legal-content :global(ol) {
        margin-bottom: var(--space-4);
        padding-left: var(--space-6);
        color: var(--text-secondary);
      }

      .legal-content :global(li) {
        margin-bottom: var(--space-2);
      }

      .legal-content :global(strong) {
        color: var(--text-primary);
        font-weight: 600;
      }

      .legal-content :global(a) {
        color: var(--mint-dark);
        text-decoration: underline;
      }

      .legal-content :global(a:hover) {
        color: var(--mint-fresh);
      }

      .legal-content :global(hr) {
        border: none;
        border-top: 1px solid var(--border);
        margin: var(--space-8) 0;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        margin-bottom: var(--space-6);
        color: var(--text-muted);
        font-size: var(--text-sm);
      }

      .back-link:hover {
        color: var(--mint-fresh);
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="legal-page">
      <div class="container">
        <a href="/" class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6"/>
          </svg>
          Back to Home
        </a>

        <header class="legal-header">
          <h1>{title}</h1>
          {lastUpdated && <p class="legal-meta">Last Updated: {lastUpdated}</p>}
        </header>

        <div class="legal-content prose">
          <slot />
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
