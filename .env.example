# AI
ANTHROPIC_API_KEY=your_claude_api_key

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Security
ENCRYPTION_KEY=your_256_bit_hex_key

# GHL OAuth (private app, see references/flowmintv2ghl/CLAUDE.md)
GHL_CLIENT_ID=your_ghl_client_id
GHL_CLIENT_SECRET=your_ghl_client_secret
# Different per environment: localhost in dev, https://flowmint.me/... in prod
GHL_REDIRECT_URI=http://localhost:3000/api/integrations/callback
# Space-separated, per GHL portal config
GHL_OAUTH_SCOPES=locations.readonly emails/builder.write
# HMAC secret for OAuth state tokens; generate with: openssl rand -hex 32
OAUTH_STATE_SECRET=your_32_byte_hex_secret
